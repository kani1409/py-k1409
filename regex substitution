import re
def change_symbols(match):
    if match.group(0) == '&&':
        return 'and'
    return 'or'
n = int(input())
for _ in range(n):
    line = input()
    pattern = r"(?<= )(&&|\|\|)(?= )"
    result = re.sub(pattern, change_symbols, line)
    print(re.sub(pattern, change_symbols, result))
